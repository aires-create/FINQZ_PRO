# FINQZ PRO - Variáveis de Ambiente
# Copie este arquivo para .env e configure os valores

# ============================================
# CONFIGURAÇÃO OBRIGATÓRIA EM PRODUÇÃO
# ============================================

# URL base da API (OBRIGATÓRIO em produção)
VITE_API_BASE_URL=https://sua-api-producao.com

# ============================================
# DESENVOLVIMENTO
# ============================================

# Ativar modo de desenvolvimento (APENAS para desenvolvimento local)
# Valores: 'true' = modo dev, omitir = produção
VITE_DEV_MODE=false

# Usar dados mockados (APENAS em modo DEV)
# Valores: 'true' = usar mocks, 'false' = usar API real
VITE_USE_MOCKS=false
