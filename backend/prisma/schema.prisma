// ============================================
// FINQZ PRO - Prisma Schema
// Enterprise SaaS Fintech Database Schema
// Multi-tenant, RBAC, UUID-based, Soft-delete
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE MULTI-TENANT
// ============================================

model Tenant {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  domain     String?   @unique
  plan       String    @default("standard")
  settings   Json?
  isActive   Boolean   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  users         User[]
  organizations Organization[]
  memberships   Membership[]
  roles         Role[]
  partners      Partner[]
  leads         Lead[]
  customers     Customer[]
  pipelines     Pipeline[]
  stages        Stage[]
  opportunities Opportunity[]
  activities    Activity[]
  bankProposals BankProposal[]
  commissions   Commission[]
  rolePermissions RolePermission[]
  userRoles     UserRole[]
  auditLogs     AuditLog[]

  @@index([domain])
  @@index([isActive])
  @@index([deletedAt])
  @@map("tenants")
}

model Organization {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  code        String
  description String?
  type        String    @default("department")
  level       Int       @default(1)
  settings    Json?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId String  @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  parentId String?     @db.Uuid
  parent   Organization? @relation("OrganizationHierarchy", fields: [parentId], references: [id])
  children Organization[] @relation("OrganizationHierarchy")

  memberships Membership[]
  users       User[]
  auditLogs   AuditLog[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([type])
  @@index([level])
  @@index([isActive])
  @@map("organizations")
}

model Membership {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role        String    @default("member")
  permissions Json?
  isActive    Boolean   @default(true)
  joinedAt    DateTime  @default(now())
  invitedAt   DateTime?
  invitedById String?   @db.Uuid
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invitedBy User? @relation("MembershipInvitedBy", fields: [invitedById], references: [id])
  auditLogs AuditLog[]

  @@unique([userId, organizationId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
  @@map("memberships")
}

model Partner {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String
  name      String
  type      String
  document  String?
  email     String?
  phone     String?
  status    String  @default("active")
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  parentId String? @db.Uuid
  parent   Partner? @relation("PartnerHierarchy", fields: [parentId], references: [id])
  children Partner[] @relation("PartnerHierarchy")

  users      User[]
  customers  Customer[]
  leads      Lead[]
  opportunities Opportunity[]
  bankProposals BankProposal[]
  commissions Commission[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([status])
  @@map("partners")
}

// ============================================
// RBAC
// ============================================

enum RoleType {
  SYSTEM
  ADMIN
  MANAGER
  USER
  AUDITOR
  SUPPORT
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  VIEW
  APPROVE
  ASSIGN
  REVOKE
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String
  type        RoleType         @default(USER)
  description String?
  priority    Int              @default(0)
  isSystem    Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  parentId String? @db.Uuid
  parent   Role?   @relation("RoleHierarchy", fields: [parentId], references: [id])
  children Role[]  @relation("RoleHierarchy")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@index([priority])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String           @unique
  slug        String           @unique
  description String?
  resource    String
  action      PermissionAction
  createdAt   DateTime         @default(now())

  rolePermissions RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  tenantId     String     @db.Uuid
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String     @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@index([tenantId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  tenantId   String @db.Uuid
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String @db.Uuid
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId     String @db.Uuid
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([tenantId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String
  emailNormalized String
  password        String
  firstName       String
  lastName        String
  phone           String?
  department      String?
  jobTitle        String?
  avatar          String?
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  lastLoginIp     String?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  organizationId String?      @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id])

  partnerId String? @db.Uuid
  partner   Partner? @relation(fields: [partnerId], references: [id])

  userRoles       UserRole[]
  createdLeads    Lead[]      @relation("LeadCreatedBy")
  ownedLeads      Lead[]      @relation("LeadOwner")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  createdProposals BankProposal[] @relation("ProposalCreatedBy")
  activities      Activity[]
  commissions     Commission[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  memberships     Membership[]
  invitedMemberships Membership[] @relation("MembershipInvitedBy")

  @@unique([tenantId, emailNormalized])
  @@index([tenantId])
  @@index([organizationId])
  @@index([partnerId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

// ============================================
// CRM
// ============================================

model Lead {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName       String
  lastName        String
  email           String?
  emailNormalized String?
  phone           String?
  cpf             String?
  birthDate       DateTime?
  address         Json?
  income          Float?
  score           Int       @default(0)
  status          String    @default("prospect")
  source          String?
  notes           String?
  tags            Json?
  convertedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  partnerId String? @db.Uuid
  partner   Partner? @relation(fields: [partnerId], references: [id])

  createdById String @db.Uuid
  creator     User   @relation("LeadCreatedBy", fields: [createdById], references: [id])

  ownerId String? @db.Uuid
  owner   User? @relation("LeadOwner", fields: [ownerId], references: [id])

  opportunities Opportunity[]
  activities    Activity[]
  bankProposals BankProposal[]
  customers      Customer[]

  @@unique([tenantId, cpf])
  @@unique([tenantId, emailNormalized])
  @@index([tenantId])
  @@index([partnerId])
  @@index([status])
  @@index([cpf])
  @@index([score])
  @@index([createdById])
  @@index([ownerId])
  @@index([deletedAt])
  @@map("leads")
}

model Customer {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerCode  String
  firstName     String
  lastName      String
  email         String
  emailNormalized String
  phone         String?
  cpf           String
  birthDate     DateTime?
  monthlyIncome Float?
  annualIncome  Float?
  kycStatus     String    @default("pending")
  kycVerifiedAt DateTime?
  riskLevel     String    @default("medium")
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  partnerId String? @db.Uuid
  partner   Partner? @relation(fields: [partnerId], references: [id])

  leadId String? @db.Uuid
  lead   Lead? @relation(fields: [leadId], references: [id])

  parentCustomerId String? @db.Uuid
  parentCustomer   Customer?  @relation("CustomerHierarchy", fields: [parentCustomerId], references: [id])
  childCustomers   Customer[] @relation("CustomerHierarchy")

  opportunities Opportunity[]
  activities    Activity[]
  bankProposals BankProposal[]
  commissions   Commission[]

  @@unique([tenantId, cpf])
  @@index([partnerId])
  @@unique([tenantId, customerCode])
  @@unique([tenantId, emailNormalized])
  @@index([tenantId])
  @@index([kycStatus])
  @@index([isActive])
  @@index([deletedAt])
  @@map("customers")
}

model Pipeline {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  description String?
  isDefault  Boolean   @default(false)
  isActive   Boolean   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stages Stage[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([isDefault])
  @@index([isActive])
  @@map("pipelines")
}

model Stage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  order     Int       @default(0)
  isWon     Boolean   @default(false)
  isLost    Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  pipelineId String   @db.Uuid
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  opportunities Opportunity[]

  @@unique([pipelineId, order])
  @@index([pipelineId])
  @@index([tenantId])
  @@map("stages")
}

model Opportunity {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  description       String?
  amount            Float
  currency          String    @default("BRL")
  probability       Int       @default(50)
  status            String    @default("open")
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  partnerId String? @db.Uuid
  partner   Partner? @relation(fields: [partnerId], references: [id])

  leadId String? @db.Uuid
  lead   Lead? @relation(fields: [leadId], references: [id])

  customerId String? @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  pipelineId String @db.Uuid
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  stageId String @db.Uuid
  stage   Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)

  ownerId String? @db.Uuid
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id])

  activities    Activity[]
  bankProposals BankProposal[]
  commissions   Commission[]

  @@index([tenantId])
  @@index([status])
  @@index([stageId])
  @@index([leadId])
  @@index([customerId])
  @@index([ownerId])
  @@index([partnerId])
  @@index([deletedAt])
  @@map("opportunities")
}

model Activity {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         String    @default("note")
  title        String
  description  String?
  status       String    @default("pending")
  scheduledFor DateTime?
  completedAt  DateTime?
  duration     Int?
  notes        String?
  attachments  Json?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  leadId String? @db.Uuid
  lead   Lead? @relation(fields: [leadId], references: [id])

  customerId String? @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  opportunityId String? @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([leadId])
  @@index([customerId])
  @@index([opportunityId])
  @@index([deletedAt])
  @@map("activities")
}

// ============================================
// FINANCEIRO
// ============================================

model BankProposal {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  proposalNumber String
  productType    String
  title          String
  status         String    @default("draft")
  amount         Float
  interestRate   Float
  term           Int
  monthlyPayment Float
  totalCost      Float
  kycStatus      String    @default("pending")
  kycVerifiedAt  DateTime?
  kycExpireAt    DateTime?
  documents      Json?
  fees           Json?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  partnerId String? @db.Uuid
  partner   Partner? @relation(fields: [partnerId], references: [id])

  leadId String? @db.Uuid
  lead   Lead? @relation(fields: [leadId], references: [id])

  customerId String? @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  opportunityId String? @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  createdById String @db.Uuid
  creator     User   @relation("ProposalCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@unique([tenantId, proposalNumber])
  @@index([partnerId])
  @@index([status])
  @@index([kycStatus])
  @@index([leadId])
  @@index([customerId])
  @@index([opportunityId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("bank_proposals")
}

model Commission {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commissionNumber String
  type             String    @default("sale")
  amount           Float
  percentage       Float
  status           String    @default("pending")
  referenceDate    DateTime
  approvedAt       DateTime?
  paidAt           DateTime?
  dueDate          DateTime
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  partnerId String? @db.Uuid
  partner   Partner? @relation(fields: [partnerId], references: [id])

  customerId String? @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunityId String? @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  @@index([tenantId])
  @@unique([tenantId, commissionNumber])
  @@index([status])
  @@index([type])
  @@index([userId])
  @@index([customerId])
  @@index([opportunityId])
  @@index([deletedAt])
  @@map("commissions")
}

// ============================================
// AUDIT & SECURITY
// ============================================

model AuditLog {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action      String
  entity      String
  entityId    String?
  changes     Json?
  description String?
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  requestId   String?
  metadata    Json?
  riskLevel   String? @default("low")
  complianceTags Json?
  createdAt   DateTime @default(now())

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  organizationId String? @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id])

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id])

  membershipId String? @db.Uuid
  membership   Membership? @relation(fields: [membershipId], references: [id])

  @@index([tenantId])
  @@index([organizationId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([membershipId])
  @@index([createdAt])
  @@index([riskLevel])
  @@map("audit_logs")
}

model RefreshToken {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token         String    @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}
