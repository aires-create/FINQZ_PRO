# FINQZ PRO backend environment example
# Copy to .env for local development. Never commit real secrets.

# Runtime
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
# Local Node/Prisma runtime uses localhost.
DATABASE_URL=postgresql://finqz_user:finqz_password@localhost:5432/finqz_pro_dev?schema=public

# Docker Compose database bootstrap values
POSTGRES_USER=finqz_user
POSTGRES_PASSWORD=finqz_password
POSTGRES_DB=finqz_pro_dev

# Redis
# Local runtime can use redis://localhost:6379.
# Docker Compose API runtime should use redis://redis:6379.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
# Development-only sample values. Replace before any production/staging use.
JWT_SECRET=dev-only-jwt-secret-change-before-production-32chars
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-before-production-32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Optional application settings
BCRYPT_ROUNDS=10
LOG_LEVEL=info
LOG_FILE=logs/app.log
SWAGGER_TITLE=FINQZ PRO API
SWAGGER_VERSION=1.0.0
SWAGGER_DESCRIPTION=FINQZ PRO backend API documentation
SWAGGER_PATH=/api-docs
