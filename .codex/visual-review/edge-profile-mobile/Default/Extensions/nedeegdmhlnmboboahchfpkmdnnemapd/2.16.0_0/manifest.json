{
   "background": {
      "persistent": false,
      "scripts": [ "scripts/forge-cipher.js", "scripts/signalr-client-1.0.4.js", "scripts/sjcl.js", "scripts/event-page.js" ]
   },
   "browser_action": {
      "default_icon": {
         "19": "img/browser-icon-small.png",
         "38": "img/browser-icon-big.png"
      },
      "default_popup": "popup.html",
      "default_title": "Web PKI options"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "scripts/content-script.js" ],
      "matches": [ "http://*/*", "https://*/*" ]
   } ],
   "default_locale": "en",
   "description": "Extension to use digital certificates within webpages",
   "icons": {
      "128": "img/icon128.png",
      "16": "img/icon16.png",
      "32": "img/icon32.png",
      "48": "img/icon48.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "Web PKI",
   "permissions": [ "nativeMessaging", "storage", "downloads", "tabs" ],
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "2.16.0"
}
